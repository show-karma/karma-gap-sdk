# RPC URLs for supported networks
# Get your API keys from Alchemy (https://www.alchemy.com/), Infura (https://infura.io/),
# or use public RPC endpoints (noted below where available)

# Mainnets
RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BASE=https://mainnet.base.org  # Public endpoint available
RPC_CELO=https://forno.celo.org  # Public endpoint available
RPC_SEI=https://evm-rpc.sei-apis.com  # Public endpoint available
RPC_LISK=https://lisk.drpc.org  # Public endpoint available
RPC_SCROLL=https://scroll-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_POLYGON=https://polygon-rpc.com  # Public endpoint available

# Testnets
RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_OPTIMISM_SEPOLIA=https://opt-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_BASE_SEPOLIA=https://sepolia.base.org  # Public endpoint available
RPC_SEI_TESTNET=https://evm-rpc-testnet.sei-apis.com  # Public endpoint available

# Private key for signing transactions (optional, for scripts)
# PRIVATE_KEY=your_private_key_here
